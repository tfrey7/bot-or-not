{
  "name": "bot-or-not",
  "version": "3.0.0",
  "description": "",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "sign": "source .env && npm run build && web-ext sign --api-key=$AMO_API_KEY --api-secret=$AMO_API_SECRET --channel unlisted --source-dir dist",
    "format": "prettier --write \"src/**/*.js\"",
    "lint": "eslint \"src/**/*.js\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "vite": "^8.0.13",
    "vite-plugin-web-extension": "^4.5.1",
    "web-ext": "^10.1.0"
  }
}
