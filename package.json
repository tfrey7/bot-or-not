{
  "name": "bot-or-not",
  "version": "7.4.3",
  "description": "",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "build": "vite build",
    "sign": "source .env && npm run build && web-ext sign --api-key=$AMO_API_KEY --api-secret=$AMO_API_SECRET --channel unlisted --source-dir dist",
    "updates-json": "node scripts/update-updates-json.mjs && node scripts/update-changelog.mjs",
    "investigate": "source .env && tsx scripts/investigate.ts",
    "regen-readme": "tsx scripts/regen-readme.ts",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-web-extension": "^4.5.1",
    "web-ext": "^10.1.0"
  },
  "dependencies": {
    "p-queue": "^9.3.0",
    "p-retry": "^8.0.0",
    "uplot": "^1.6.32"
  }
}
