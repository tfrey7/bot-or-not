{
  "manifest_version": 3,
  "name": "Bot or Not",
  "version": "7.4.2",
  "description": "Flag suspicious Reddit accounts",
  "browser_specific_settings": {
    "gecko": {
      "id": "bot-or-not@timothyfrey",
      "update_url": "https://tfrey7.github.io/bot-or-not/updates.json"
    }
  },
  "background": {
    "scripts": [
      "src/background.ts"
    ]
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://www.reddit.com/*"
  ],
  "optional_host_permissions": [
    "https://www.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://reddit.com/*",
        "*://old.reddit.com/*",
        "*://www.reddit.com/*"
      ],
      "js": [
        "src/content_script.ts"
      ],
      "css": [
        "src/content_script.css"
      ]
    },
    {
      "matches": [
        "*://www.google.com/search*"
      ],
      "js": [
        "src/features/google-harvest/search_listener.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Bot or Not",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon.png",
        "icons/icon-bot.png",
        "icons/chromes-investigating.webp",
        "icons/chromes-corkboard.webp",
        "icons/chromes-peephole.webp",
        "icons/chromes-typewriter.webp",
        "icons/chromes-magnifier-doorknob.webp",
        "icons/chromes-plaster-cast.webp",
        "icons/chromes-microscope.webp",
        "icons/chromes-wiretap.webp",
        "icons/chromes-foggy-alley.webp",
        "icons/chromes-filing-cabinet.webp",
        "icons/chromes-darkroom.webp",
        "icons/chromes-empty-dossier.png",
        "icons/persona/*"
      ],
      "matches": [
        "*://reddit.com/*",
        "*://old.reddit.com/*",
        "*://www.reddit.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon.png"
  }
}
