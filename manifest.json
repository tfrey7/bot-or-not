{
  "manifest_version": 3,
  "name": "Bot or Not",
  "version": "1.1.0",
  "description": "Flag suspicious Reddit accounts",
  "browser_specific_settings": {
    "gecko": {
      "id": "bot-or-not@timothyfrey"
    }
  },
  "background": {
    "scripts": [
      "src/factors.js",
      "src/verdict.js",
      "src/triangle/verdict_triangle.js",
      "src/regions.js",
      "src/bot_analysis.js",
      "src/triangle/bot_analysis_triangle.js",
      "src/background.js"
    ]
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://www.reddit.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://reddit.com/*", "*://old.reddit.com/*", "*://www.reddit.com/*"],
      "js": ["src/verdict.js", "src/content_script.js"],
      "css": ["src/content_script.css"]
    }
  ],
  "action": {
    "default_title": "Bot or Not",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png", "icons/icon-bot.png"],
      "matches": ["*://reddit.com/*", "*://old.reddit.com/*", "*://www.reddit.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon.png"
  }
}
