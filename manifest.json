{
  "manifest_version": 3,
  "name": "Bot or Not",
  "version": "3.10.2",
  "description": "Flag suspicious Reddit accounts",
  "browser_specific_settings": {
    "gecko": {
      "id": "bot-or-not@timothyfrey",
      "update_url": "https://tfrey7.github.io/bot-or-not/updates.json"
    }
  },
  "background": {
    "scripts": ["src/background.ts"]
  },
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://www.reddit.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://reddit.com/*",
        "*://old.reddit.com/*",
        "*://www.reddit.com/*"
      ],
      "js": ["src/content_script.ts"],
      "css": ["src/content_script.css"]
    }
  ],
  "action": {
    "default_title": "Bot or Not",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png", "icons/icon-bot.png"],
      "matches": [
        "*://reddit.com/*",
        "*://old.reddit.com/*",
        "*://www.reddit.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon.png"
  }
}
