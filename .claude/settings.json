  { 
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "npm run typecheck >&2 && npm run lint >&2 && npm run format >&2 || exit 2",
              "if": "Bash(git commit*)",
              "timeout": 180,
              "statusMessage": "typecheck / lint / format before commit"
            }
          ]
        }
      ] 
    }
  }
